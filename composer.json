{
  "name": "d3nengineer/stream-encryption-psr7",
  "description": "PSR-7 stream decorators for media encryption (AES-CBC + HKDF + HMAC)",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "psr-7",
    "stream",
    "encryption",
    "aes-cbc",
    "hmac"
  ],
  "autoload": {
    "psr-4": {
      "Infra\\StreamEncryption\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Infra\\StreamEncryption\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "psr/http-message": "^1.0 || ^2.0",
    "guzzlehttp/psr7": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "lint": "find src tests -name '*.php' -print0 | xargs -0 -n1 php -l",
    "test": "vendor/bin/phpunit",
    "check": [
      "@composer validate --strict",
      "@lint",
      "@test"
    ]
  }
}
